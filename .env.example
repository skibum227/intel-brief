# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Atlassian (Confluence + Jira)
# Create scoped read-only tokens at: https://id.atlassian.com/manage-profile/security/api-tokens
# Create one token per product (Jira, Confluence) with read-only scopes
ATLASSIAN_EMAIL=you@yourcompany.com
JIRA_API_TOKEN=...
CONFLUENCE_API_TOKEN=...
ATLASSIAN_BASE_URL=https://yourcompany.atlassian.net

# Slack
# Create app at https://api.slack.com/apps → "User Token Scopes" (xoxp-...)
# Required scopes: channels:history, channels:read, groups:history, groups:read, users:read
SLACK_USER_TOKEN=xoxp-...
